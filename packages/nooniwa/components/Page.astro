---
import config from "virtual:nooniwa/config";
import pkg from "../package.json";
import "virtual:nooniwa/styles";

import SkipLink from "virtual:nooniwa/components/SkipLink";
import PageFrame from "virtual:nooniwa/components/PageFrame";
import PageMain from "virtual:nooniwa/components/PageMain";
import PageBeforeBody from "virtual:nooniwa/components/PageBeforeBody";
import PageBody from "virtual:nooniwa/components/PageBody";
import PageAfterBody from "virtual:nooniwa/components/PageAfterBody";
import PageOverlays from "virtual:nooniwa/components/PageOverlays";
import type { MarkdownHeading } from "astro";
import type { HeadConfig } from "../schemas/head";
import type { BacklinkEntry } from "../utils/backlinks";
import type { TreeNode } from "../utils/folder-tree";
import type { GraphNode, GraphLink } from "../utils/graph";

interface Props {
  title: string;
  description?: string | undefined;
  created?: Date | undefined;
  updated?: Date | undefined;
  tags?: string[] | undefined;
  backlinks: BacklinkEntry[];
  currentPath: string;
  folderTree: TreeNode[];
  headings: MarkdownHeading[];
  localGraph: { nodes: GraphNode[]; links: GraphLink[] };
  hasFullGraph: boolean;
}

const {
  title,
  description,
  created,
  updated,
  tags = [],
  backlinks,
  currentPath,
  folderTree,
  headings,
  localGraph,
  hasFullGraph,
} = Astro.props;

const { siteTitle, favicon, ogImage, head, rss } = config;

const generator = `${pkg.name} v${pkg.version}`;

const headTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;

const canonicalUrl = Astro.site
  ? new URL(currentPath, Astro.site).href
  : undefined;
const ogImageUrl =
  ogImage && Astro.site ? new URL(ogImage.src, Astro.site).href : undefined;
const rssUrl = Astro.site ? new URL("/rss.xml", Astro.site).href : undefined;
const ogType = currentPath === "/" ? "website" : "article";
---

<!doctype html>
<html lang={config.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{headTitle}</title>

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    {
      head.map(({ tag: Tag, attrs, content }: HeadConfig[number]) => (
        <Tag {...attrs} set:html={content} />
      ))
    }

    {favicon.ico && <link rel="icon" href={favicon.ico} sizes="32x32" />}
    {favicon.svg && <link rel="icon" href={favicon.svg} type="image/svg+xml" />}
    {
      favicon.appleTouchIcon && (
        <link
          rel="apple-touch-icon"
          href={favicon.appleTouchIcon}
          sizes="180x180"
        />
      )
    }

    {
      rss && rssUrl && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={siteTitle}
          href={rssUrl}
        />
      )
    }

    {description && <meta name="description" content={description} />}

    <meta name="generator" content={Astro.generator} />
    <meta name="generator" content={generator} />

    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content={siteTitle} />
    {
      ogImage && ogImageUrl && (
        <>
          <meta property="og:image" content={ogImageUrl} />
          <meta property="og:image:alt" content={ogImage.alt} />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <script is:inline>
      (function () {
        const raw = localStorage.getItem("nooniwa:color-theme");
        const setting =
          raw === "light" || raw === "dark" || raw === "auto" ? raw : "auto";
        const effective =
          setting === "auto"
            ? window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
            : setting;
        if (effective === "dark") {
          document.documentElement.classList.add("dark");
        }
        document.documentElement.dataset.theme = effective;
      })();
    </script>

    <script is:inline>
      if (Number(sessionStorage.getItem("nooniwa:sidebar-scroll")) > 0) {
        document.documentElement.dataset.sidebarRestore = "";
      }
    </script>
  </head>
  <body
    class="min-h-svh bg-(--color-background) text-(--color-foreground) print:min-h-0"
  >
    <SkipLink />
    <PageFrame
      currentPath={currentPath}
      folderTree={folderTree}
      headings={headings}
      localGraph={localGraph}
      hasFullGraph={hasFullGraph}
    >
      <PageMain>
        <article data-pagefind-body>
          <PageBeforeBody
            title={title}
            created={created}
            updated={updated}
            tags={tags}
          />
          <PageBody>
            <slot />
          </PageBody>
        </article>

        <PageAfterBody backlinks={backlinks} />
      </PageMain>
    </PageFrame>

    <PageOverlays localGraph={localGraph} currentPath={currentPath} />

    <style is:global>
      html {
        scroll-padding-top: 4.25rem;
        overflow-y: scroll;
      }
    </style>

    <script>
      import { initCalloutFold } from "../scripts/callout";
      import { initSidebarScrollPersist } from "../scripts/sidebar-scroll";
      import { initPagePreview } from "../scripts/page-preview";
      import { initFootnotePopover } from "../scripts/footnote-popover";
      import { initHeadingAnchors } from "../scripts/heading-anchors";
      import { initHashHighlight } from "../scripts/hash-highlight";
      import { initEmbedFallback } from "../scripts/embed-fallback";

      initEmbedFallback();
      initCalloutFold();
      initHeadingAnchors();
      initPagePreview();
      initFootnotePopover();
      initHashHighlight();
      initSidebarScrollPersist();

      document.documentElement.removeAttribute("data-sidebar-restore");
    </script>
  </body>
</html>
