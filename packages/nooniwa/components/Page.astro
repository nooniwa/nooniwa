---
import config from "virtual:nooniwa/config";
import "virtual:nooniwa/styles";

import SkipLink from "virtual:nooniwa/components/SkipLink";
import PageMain from "virtual:nooniwa/components/PageMain";
import PageBeforeBody from "virtual:nooniwa/components/PageBeforeBody";
import PageBody from "virtual:nooniwa/components/PageBody";
import PageAfterBody from "virtual:nooniwa/components/PageAfterBody";
import Footer from "virtual:nooniwa/components/Footer";
import type { BacklinkEntry } from "../utils/backlinks";

interface Props {
  title: string;
  description?: string | undefined;
  created?: Date | undefined;
  updated?: Date | undefined;
  tags?: string[] | undefined;
  backlinks: BacklinkEntry[];
}

const {
  title,
  description,
  created,
  updated,
  tags = [],
  backlinks,
} = Astro.props;

const { siteTitle } = config;

const headTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang={config.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{headTitle}</title>
    {description && <meta name="description" content={description} />}

    <script is:inline>
      (function () {
        const raw = localStorage.getItem("nooniwa:color-theme");
        const setting =
          raw === "light" || raw === "dark" || raw === "auto" ? raw : "auto";
        const effective =
          setting === "auto"
            ? window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
            : setting;
        if (effective === "dark") {
          document.documentElement.classList.add("dark");
        }
        document.documentElement.dataset.theme = effective;
      })();
    </script>
  </head>
  <body
    class="min-h-svh bg-(--color-background) text-(--color-foreground) print:min-h-0"
  >
    <SkipLink />
    <PageMain>
      <article data-pagefind-body>
        <PageBeforeBody
          title={title}
          created={created}
          updated={updated}
          tags={tags}
        />
        <PageBody>
          <slot />
        </PageBody>
      </article>
      <PageAfterBody backlinks={backlinks} />
    </PageMain>
    <Footer />

    <style is:global>
      html {
        scroll-padding-top: 4.25rem;
        overflow-y: scroll;
      }
    </style>
  </body>
</html>
