---
import PageTitle from "virtual:nooniwa/components/PageTitle";
import PageMetadata from "virtual:nooniwa/components/PageMetadata";

interface Props {
  title: string;
  created?: Date | undefined;
  updated?: Date | undefined;
  tags?: string[];
}

const { title, created, updated, tags = [] } = Astro.props;
---

<header class="prose prose-nooniwa mb-8 max-w-none">
  <PageTitle title={title} />
  <PageMetadata created={created} updated={updated} tags={tags} />
</header>
