---
import Header from "virtual:nooniwa/components/Header";
import Footer from "virtual:nooniwa/components/Footer";
import PageLeft from "virtual:nooniwa/components/PageLeft";
import PageRight from "virtual:nooniwa/components/PageRight";
import type { MarkdownHeading } from "astro";
import type { TreeNode } from "../utils/folder-tree";
import type { GraphNode, GraphLink } from "../utils/graph";

interface Props {
  currentPath: string;
  folderTree: TreeNode[];
  headings: MarkdownHeading[];
  localGraph: { nodes: GraphNode[]; links: GraphLink[] };
  hasFullGraph: boolean;
}

const { currentPath, folderTree, headings, localGraph, hasFullGraph } =
  Astro.props as Props;
---

<Header />

<div
  class="page-frame mx-auto grid min-h-svh max-w-352 grid-cols-[minmax(0,1fr)] md:grid-cols-[--spacing(80)_minmax(0,1fr)] lg:grid-cols-[--spacing(80)_minmax(0,1fr)_--spacing(80)] print:block print:min-h-0 print:max-w-none"
>
  <PageLeft currentPath={currentPath} folderTree={folderTree} />

  <div class="flex flex-col">
    <div class="h-14 print:hidden"></div>
    <slot />
    <Footer />
  </div>

  <PageRight
    headings={headings}
    graphNodes={localGraph.nodes}
    graphLinks={localGraph.links}
    hasFullGraph={hasFullGraph}
    currentPath={currentPath}
  />
</div>
