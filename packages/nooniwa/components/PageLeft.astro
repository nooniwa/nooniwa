---
import config from "virtual:nooniwa/config";
import FolderTree from "virtual:nooniwa/components/FolderTree";
import Search from "virtual:nooniwa/components/Search";
import SocialIcons from "virtual:nooniwa/components/SocialIcons";
import ThemeToggle from "virtual:nooniwa/components/ThemeToggle";
import type { TreeNode } from "../utils/folder-tree";

interface Props {
  currentPath: string;
  folderTree: TreeNode[];
}

const { currentPath, folderTree } = Astro.props as Props;
---

<aside
  id="site-menu"
  class="page-left fixed top-14 left-0 z-50 flex h-[calc(100svh-(--spacing(14)))] w-full flex-col overflow-hidden bg-(--color-background) md:sticky md:left-auto md:z-auto md:w-auto md:border-r md:border-(--color-border) print:hidden"
>
  {
    config.search && (
      <div class="pt-4">
        <Search />
      </div>
    )
  }

  <nav
    aria-label="Folder tree"
    class:list={["flex-1 overflow-y-auto px-2 pb-8", !config.search && "pt-6"]}
  >
    <FolderTree nodes={folderTree} currentPath={currentPath} />
  </nav>

  <script is:inline>
    (function () {
      var nav = document.querySelector(".page-left nav");
      var n = Number(sessionStorage.getItem("nooniwa:sidebar-scroll"));
      if (nav && Number.isFinite(n) && n > 0) nav.scrollTop = n;
      document.documentElement.removeAttribute("data-sidebar-restore");
    })();
  </script>

  <div
    class="flex shrink-0 items-center justify-center gap-4 border-t border-(--color-border) px-4 py-3 md:hidden print:hidden"
  >
    <SocialIcons />
    <ThemeToggle />
  </div>
</aside>

<style is:global>
  .page-left nav {
    scrollbar-width: none;
    -ms-overflow-style: none;
    overscroll-behavior: contain;
  }
  .page-left nav::-webkit-scrollbar {
    display: none;
  }

  html[data-sidebar-restore] .page-left nav {
    visibility: hidden;
  }

  .page-left {
    transition: transform 0.2s ease-in-out;
  }

  @media (width < 48rem) {
    .page-left {
      transform: translateY(-100%);
      transition-duration: 0.35s;
    }
    html[data-sidebar-left="open"] .page-left {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-left {
      transition: none;
    }
  }
</style>
