---
import Icon from "./Icon.astro";
---

<div class="relative px-4 pb-4" id="search-container">
  <div class="relative">
    <Icon
      name="search"
      class="pointer-events-none absolute top-1/2 left-3 h-4 w-4 -translate-y-1/2 text-(--color-foreground-muted)"
    />
    <input
      type="text"
      id="search-input"
      placeholder="Search..."
      aria-label="Search"
      autocomplete="off"
      spellcheck="false"
      role="combobox"
      aria-expanded="false"
      aria-controls="search-results"
      aria-autocomplete="list"
      class="w-full rounded-sm border border-(--color-border) bg-transparent py-2 pr-4 pl-10 text-sm text-(--color-foreground)"
    />
  </div>
  <div
    id="search-results"
    class="search-results scrollbar-nooniwa hidden"
    role="listbox"
    aria-label="Search results"
  >
  </div>

  <div id="search-status" class="sr-only" role="status" aria-live="polite">
  </div>
</div>

<style is:global>
  .search-results {
    position: fixed;
    top: var(--dropdown-top, 0);
    left: var(--dropdown-left, 0);
    width: 400px;
    max-width: 90vw;
    max-height: var(--dropdown-max-height, 400px);
    overflow-y: auto;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    z-index: 100;
    scrollbar-width: auto;
    scrollbar-gutter: stable;
    overscroll-behavior: none;
  }

  html[data-search-open] {
    overscroll-behavior-y: none;
  }

  .dark .search-results {
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
  }

  @media (width < 48rem) {
    .search-results {
      width: calc(100vw - 2rem);
      max-width: none;
    }
  }

  .search-results.hidden {
    display: none;
  }

  .search-result-item {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.15s ease;
  }

  .search-result-item:last-child {
    border-bottom: none;
  }

  .search-result-item:hover,
  .search-result-item.selected {
    background: var(--color-background-muted);
  }

  .search-result-title {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .search-result-excerpt {
    display: block;
    font-size: 0.8125rem;
    color: var(--color-foreground-muted);
    line-height: 1.6;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  .search-result-excerpt mark {
    background: var(--color-highlight);
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }

  .search-result-source {
    display: block;
    font-size: 0.75rem;
    color: var(--color-foreground-muted);
    margin-top: 6px;
  }

  .search-empty-state {
    padding: 20px 16px;
    text-align: center;
    color: var(--color-foreground-muted);
    font-size: 0.875rem;
  }
</style>

<script>
  import {
    wrapIndex,
    optionId,
    resultsAnnouncement,
    isImeEnter,
  } from "../scripts/search-combobox";
  import {
    attachScrollGuard,
    shouldPreventWheel,
  } from "../scripts/wheel-guard";

  interface PagefindResult {
    url: string;
    excerpt: string;
    meta?: { title?: string };
  }

  interface PagefindSearchResponse {
    results: { data: () => Promise<PagefindResult> }[];
  }

  interface PagefindInstance {
    init: () => Promise<void>;
    search: (query: string) => Promise<PagefindSearchResponse>;
  }

  let pagefindInstance: PagefindInstance | null = null;
  let searchTimeout: ReturnType<typeof setTimeout> | null = null;
  let selectedIndex = -1;
  let isComposing = false;
  let searchSequence = 0;

  async function loadPagefind(): Promise<PagefindInstance | null> {
    if (import.meta.env.DEV) return null;
    if (pagefindInstance) return pagefindInstance;
    try {
      const pagefindPath = "/pagefind/pagefind.js";
      pagefindInstance = (await import(
        /* @vite-ignore */ pagefindPath
      )) as PagefindInstance;
      await pagefindInstance.init();
      return pagefindInstance;
    } catch {
      console.warn("Pagefind not available (run build first)");
      return null;
    }
  }

  function initSearch() {
    const input = document.getElementById(
      "search-input",
    ) as HTMLInputElement | null;
    const dropdown = document.getElementById("search-results");
    const statusRegion = document.getElementById("search-status");

    if (!input || !dropdown) return;

    attachScrollGuard(dropdown, (deltaY) =>
      shouldPreventWheel(deltaY, dropdown),
    );

    function announce(message: string) {
      if (statusRegion) statusRegion.textContent = message;
    }

    function openDropdown() {
      updateDropdownPosition();
      dropdown!.classList.remove("hidden");
      input!.setAttribute("aria-expanded", "true");
      document.documentElement.setAttribute("data-search-open", "");
    }

    function closeDropdown() {
      dropdown!.classList.add("hidden");
      input!.setAttribute("aria-expanded", "false");
      input!.removeAttribute("aria-activedescendant");
      selectedIndex = -1;
      document.documentElement.removeAttribute("data-search-open");
    }

    function updateDropdownPosition() {
      const inputRect = input!.getBoundingClientRect();
      const top = inputRect.bottom + 4;
      const left = inputRect.left;
      const maxHeight = window.innerHeight - inputRect.bottom - 16;

      dropdown!.style.setProperty("--dropdown-top", `${top}px`);
      dropdown!.style.setProperty("--dropdown-left", `${left}px`);
      dropdown!.style.setProperty("--dropdown-max-height", `${maxHeight}px`);
    }

    function updateSelection(newIndex: number) {
      const items = dropdown!.querySelectorAll(".search-result-item");
      if (items.length === 0) return;

      items.forEach((item) => {
        item.classList.remove("selected");
        item.setAttribute("aria-selected", "false");
      });

      selectedIndex = wrapIndex(newIndex, items.length);
      const selectedItem = items[selectedIndex]!;
      selectedItem.classList.add("selected");
      selectedItem.setAttribute("aria-selected", "true");
      selectedItem.scrollIntoView({ block: "nearest" });
      input!.setAttribute("aria-activedescendant", optionId(selectedIndex));
    }

    async function performSearch(query: string) {
      const requestId = ++searchSequence;
      selectedIndex = -1;

      if (!query.trim()) {
        closeDropdown();
        announce("");
        return;
      }

      dropdown!.innerHTML =
        '<div class="search-empty-state">Searching...</div>';
      openDropdown();

      const pf = await loadPagefind();
      if (requestId !== searchSequence) return;
      if (!pf) {
        dropdown!.innerHTML =
          '<div class="search-empty-state">Search not available (build first)</div>';
        announce("Search not available");
        return;
      }

      const search = await pf.search(query);
      const results = await Promise.all(
        search.results.slice(0, 30).map((r) => r.data()),
      );
      if (requestId !== searchSequence) return;

      if (results.length === 0) {
        dropdown!.innerHTML =
          '<div class="search-empty-state">No results found</div>';
        announce(resultsAnnouncement(0));
        return;
      }

      dropdown!.innerHTML = "";

      results.forEach((result, index) => {
        const rawTitle =
          result.meta?.title || result.url.split("/").pop() || result.url;
        const sourcePath = result.url.replace(/\/$/, "") || "/";

        const item = document.createElement("a");
        item.setAttribute("href", result.url);
        item.className =
          "search-result-item" + (index === 0 ? " selected" : "");
        item.dataset.index = String(index);
        item.id = optionId(index);
        item.setAttribute("role", "option");
        item.setAttribute("aria-selected", index === 0 ? "true" : "false");

        const titleEl = document.createElement("span");
        titleEl.className = "search-result-title";
        titleEl.textContent = rawTitle;

        const excerptEl = document.createElement("span");
        excerptEl.className = "search-result-excerpt";
        excerptEl.innerHTML = result.excerpt || "";

        const sourceEl = document.createElement("span");
        sourceEl.className = "search-result-source";
        sourceEl.textContent = sourcePath;

        item.append(titleEl, excerptEl, sourceEl);
        dropdown!.appendChild(item);
      });

      selectedIndex = 0;
      input!.setAttribute("aria-activedescendant", optionId(0));
      announce(resultsAnnouncement(results.length));
    }

    input.addEventListener("input", () => {
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        performSearch(input.value);
      }, 200);
    });

    input.addEventListener("compositionstart", () => {
      isComposing = true;
    });

    input.addEventListener("compositionend", () => {
      isComposing = false;
    });

    input.addEventListener("focus", () => {
      if (input.value.trim() && dropdown.innerHTML.trim()) {
        openDropdown();
      }
    });

    document.addEventListener("click", (e) => {
      const container = document.getElementById("search-container");
      if (container && !container.contains(e.target as Node)) {
        closeDropdown();
      }
    });

    input.addEventListener("keydown", (e) => {
      const items = dropdown.querySelectorAll(".search-result-item");

      if (e.key === "Escape") {
        closeDropdown();
        input.blur();
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (items.length > 0) {
          updateSelection(selectedIndex + 1);
        }
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (items.length > 0) {
          updateSelection(selectedIndex - 1);
        }
      } else if (e.key === "Enter") {
        if (isImeEnter(e, isComposing)) return;
        e.preventDefault();
        if (selectedIndex >= 0 && selectedIndex < items.length) {
          const selectedItem = items[selectedIndex]!;
          const href = selectedItem.getAttribute("href");
          if (href) {
            window.location.href = href;
          }
        }
      }
    });

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        input.focus();
        input.select();
      }
    });
  }

  initSearch();
</script>
