---
import config from "virtual:nooniwa/config";
import Icon from "./Icon.astro";
import type { SocialConfig } from "../schemas/social";

const socials: NonNullable<SocialConfig> = config.social ?? [];
const hasSocials = socials.length > 0;
---

{
  hasSocials && (
    <div class="social-icons flex items-center gap-4">
      {socials.map(({ icon, href, label }) => (
        <a
          href={href}
          target="_blank"
          rel="me noopener"
          class="text-(--color-accent) hover:text-(--color-accent-hover)"
        >
          <span class="sr-only">{label ?? icon}</span>
          <Icon name={icon} class="h-4 w-4" aria-hidden="true" />
        </a>
      ))}
    </div>
  )
}

<style>
  .social-icons::after {
    content: "";
    height: 2rem;
    border-inline-end: 1px solid var(--color-border);
  }
</style>
