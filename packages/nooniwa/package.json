{
  "name": "nooniwa",
  "version": "0.1.2",
  "description": "nooniwa is an Astro theme (Astro integration) for digital gardens. Your Markdown notes become a website.",
  "keywords": [
    "astro",
    "withastro",
    "astro-integration",
    "digital-garden"
  ],
  "homepage": "https://nooniwa.dev",
  "license": "MIT",
  "author": "Ryota Hagihara",
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema.ts",
    "./loaders": "./loaders.ts",
    "./routes/*": "./routes/*"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nooniwa/nooniwa.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro-expressive-code": "^0.43.1",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "github-slugger": "^2.0.0",
    "katex": "^0.17.0",
    "node-html-parser": "^8.0.3",
    "pagefind": "^1.5.2",
    "playwright": "^1.61.1",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/unist": "^3.0.3",
    "astro": "^6.1.1",
    "mdast-util-to-hast": "^13.2.1",
    "vfile": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "astro": "^6.0.0 || ^7.0.0"
  }
}
