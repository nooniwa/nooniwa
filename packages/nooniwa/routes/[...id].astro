---
import { getCollection, render } from "astro:content";
import config from "virtual:nooniwa/config";
import Page from "virtual:nooniwa/components/Page";
import { buildBacklinksMap, getBacklinksForPage } from "../utils/backlinks";
import { buildFolderTree } from "../utils/folder-tree";
import { getLocalGraph } from "../utils/graph";
import { getSiteData } from "../utils/site-data";
import { isListablePage } from "../utils/pages";
import { slugToUrl } from "../utils/slug";

export async function getStaticPaths() {
  const pages = await getCollection("pages", isListablePage);
  const { pageLinks, fullGraphData } = await getSiteData();
  const backlinksMap = buildBacklinksMap(pageLinks);
  const folderTree = buildFolderTree(pages);
  const hasFullGraph = fullGraphData.nodes.length > 0;

  return pages.map((page) => {
    const currentPath = slugToUrl(page.id);
    return {
      params: { id: page.id === "index" ? undefined : page.id },
      props: {
        page,
        backlinks: getBacklinksForPage(page.id, backlinksMap),
        folderTree,
        currentPath,
        localGraph: getLocalGraph(fullGraphData, currentPath, 1),
        hasFullGraph,
      },
    };
  });
}
const { siteTitle, siteDescription } = config;

const { page, backlinks, folderTree, currentPath, localGraph, hasFullGraph } =
  Astro.props;
const { Content, headings } = await render(page);

const title =
  page.id === "index"
    ? page.data.title || siteTitle
    : page.data.title || page.id.split("/").pop() || "Untitled";

const description = page.data.description ?? siteDescription;

const { created, updated, tags } = page.data;
---

<Page
  title={title}
  description={description}
  created={created}
  updated={updated}
  tags={tags}
  backlinks={backlinks}
  folderTree={folderTree}
  currentPath={currentPath}
  headings={headings}
  localGraph={localGraph}
  hasFullGraph={hasFullGraph}
>
  <Content />
</Page>
